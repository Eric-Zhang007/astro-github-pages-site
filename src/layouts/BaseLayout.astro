---
import { navItems, profile, sitePath } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const { title = `${profile.name} • Personal Site`, description = 'Eric Zhang 的个人主页：研究、笔记、项目与博客。' } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={sitePath('favicon.svg')} />
    <link rel="icon" href={sitePath('favicon.ico')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="page">
      <header class="topbar">
        <a class="brand" href={sitePath()}>{profile.brand}</a>
        <nav aria-label="Primary navigation">
          {navItems.map((item) => <a href={sitePath(item.href)}>{item.label}</a>)}
        </nav>
      </header>

      <slot />
    </div>
    <div class="cursor-glow" aria-hidden="true"></div>
    <div class="particle-layer" aria-hidden="true"></div>
    <script>
      const glow = document.querySelector('.cursor-glow');
      const particleLayer = document.querySelector('.particle-layer');
      const progress = document.querySelector('.read-progress');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!reduceMotion && glow instanceof HTMLElement) {
        window.addEventListener('pointermove', (event) => {
          glow.style.transform = `translate(${event.clientX}px, ${event.clientY}px)`;
        }, { passive: true });
      }

      if (!reduceMotion && particleLayer instanceof HTMLElement) {
        window.addEventListener('click', (event) => {
          for (let index = 0; index < 10; index += 1) {
            const particle = document.createElement('span');
            const angle = (Math.PI * 2 * index) / 10;
            const distance = 28 + Math.random() * 34;
            particle.style.left = `${event.clientX}px`;
            particle.style.top = `${event.clientY}px`;
            particle.style.setProperty('--dx', `${Math.cos(angle) * distance}px`);
            particle.style.setProperty('--dy', `${Math.sin(angle) * distance}px`);
            particleLayer.appendChild(particle);
            window.setTimeout(() => particle.remove(), 720);
          }
        });
      }

      if (progress instanceof HTMLElement) {
        const updateProgress = () => {
          const max = document.documentElement.scrollHeight - window.innerHeight;
          const ratio = max > 0 ? window.scrollY / max : 0;
          progress.style.transform = `scaleX(${Math.min(1, Math.max(0, ratio))})`;
        };
        updateProgress();
        window.addEventListener('scroll', updateProgress, { passive: true });
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --bg: #f5f7fb;
    --card: rgba(255, 255, 255, 0.76);
    --card-solid: #ffffff;
    --text: #1b2028;
    --muted: #66707f;
    --line: rgba(31, 35, 42, 0.1);
    --accent: #557f97;
    --accent-strong: #2f6e91;
    --accent-soft: rgba(101, 158, 185, 0.18);
    --violet-soft: rgba(137, 124, 255, 0.16);
    --warm-soft: rgba(255, 196, 137, 0.2);
    --shadow: 0 24px 80px rgba(34, 42, 54, 0.1);
    font-family:
      ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "PingFang SC", "Microsoft YaHei", sans-serif;
    background: var(--bg);
    color: var(--text);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0b0b10;
      --card: rgba(22, 24, 31, 0.78);
      --card-solid: #151820;
      --text: #f4f6fb;
      --muted: #a1a7b3;
      --line: rgba(255, 255, 255, 0.1);
      --accent: #80bdd7;
      --accent-strong: #9de4ff;
      --accent-soft: rgba(128, 189, 215, 0.16);
      --violet-soft: rgba(154, 138, 255, 0.18);
      --warm-soft: rgba(255, 196, 137, 0.09);
      --shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
    }
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 16% 8%, var(--accent-soft), transparent 28rem),
      radial-gradient(circle at 86% 4%, var(--violet-soft), transparent 26rem),
      radial-gradient(circle at 68% 82%, var(--warm-soft), transparent 24rem),
      linear-gradient(120deg, transparent 0 49%, rgba(120, 150, 170, 0.05) 49% 51%, transparent 51% 100%),
      var(--bg);
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(120, 140, 160, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(120, 140, 160, 0.08) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.74), transparent 78%);
  }

  body::after {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: 0.34;
    background-image: radial-gradient(rgba(255, 255, 255, 0.6) 0.6px, transparent 0.6px);
    background-size: 3px 3px;
    mix-blend-mode: soft-light;
  }

  a { color: inherit; text-decoration: none; }

  .page {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 22px 0 56px;
  }

  .topbar {
    position: sticky;
    top: 14px;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 12px 14px;
    margin-bottom: 24px;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: color-mix(in srgb, var(--card-solid) 78%, transparent);
    box-shadow: var(--shadow);
    backdrop-filter: blur(16px);
  }

  .brand { font-weight: 800; letter-spacing: -0.02em; }

  nav {
    display: flex;
    flex: 1;
    justify-content: center;
    gap: 4px;
  }

  nav a {
    border-radius: 999px;
    padding: 8px 12px;
    color: var(--muted);
    font-size: 0.92rem;
  }

  nav a:hover { background: var(--accent-soft); color: var(--text); }

  .layout {
    display: grid;
    grid-template-columns: 320px minmax(0, 1fr);
    gap: 22px;
    align-items: start;
  }

  .card,
  .profile-card {
    border: 1px solid var(--line);
    border-radius: 28px;
    background: var(--card);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .profile-card {
    position: sticky;
    top: 98px;
    padding: 28px;
  }

  .avatar {
    display: grid;
    place-items: center;
    width: 96px;
    height: 96px;
    margin-bottom: 20px;
    border-radius: 30px;
    background: linear-gradient(135deg, rgba(101, 158, 185, 0.85), rgba(167, 201, 216, 0.55));
    color: #fff;
    font-size: 3rem;
    font-weight: 900;
  }

  .profile-card h1,
  .page-title h1 {
    margin: 0;
    letter-spacing: -0.04em;
  }

  .profile-card h1 { font-size: 2rem; }
  .location { margin: 8px 0 16px; color: var(--muted); }
  .links { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }

  .links a,
  .chips span,
  .pill {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 11px;
    background: var(--accent-soft);
    color: var(--text);
    font-size: 0.9rem;
  }

  .profile-card h2,
  .section-title h2 {
    margin: 0;
    font-size: 0.98rem;
    letter-spacing: -0.015em;
  }

  p { color: var(--muted); line-height: 1.75; }
  .content { display: grid; gap: 18px; }
  .intro { padding: 38px; }

  .kicker {
    margin: 0 0 10px;
    color: var(--accent);
    font-size: 0.86rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .intro h2 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(2.5rem, 6vw, 5.8rem);
    line-height: 0.96;
    letter-spacing: -0.075em;
  }

  .intro p { max-width: 720px; font-size: 1.05rem; }
  .intro-compact { min-height: 240px; align-content: end; }
  .intro-compact h2 { max-width: none; font-size: clamp(3rem, 8vw, 6.4rem); }
  .hero-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .hero-links a {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 9px 13px;
    color: var(--text);
    background: var(--accent-soft);
  }

  .more {
    display: inline-flex;
    margin-top: 8px;
    color: var(--accent);
    font-weight: 750;
  }

  .two-column {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .two-column .card,
  .stats,
  .activity,
  .list-card,
  .page-title { padding: 26px; }

  .section-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 18px;
  }

  .section-title span,
  time { color: var(--muted); font-size: 0.86rem; }
  .chips { display: flex; flex-wrap: wrap; gap: 10px; }
  .timeline, .item-list { display: grid; gap: 14px; }

  .timeline article,
  .item-list article,
  .item-list a {
    display: block;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--line);
  }

  .timeline article:last-child,
  .item-list article:last-child,
  .item-list a:last-child { padding-bottom: 0; border-bottom: 0; }
  .timeline h3, .item-list h3 { margin: 0 0 4px; font-size: 1rem; }
  .timeline p, .item-list p { margin: 0; font-size: 0.92rem; }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .stats div {
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 22px;
    background: color-mix(in srgb, var(--accent-soft) 52%, transparent);
  }

  .stats strong { display: block; font-size: 2rem; letter-spacing: -0.05em; }
  .stats span { color: var(--muted); font-size: 0.88rem; }

  .empty {
    margin: 0;
    padding: 18px;
    border: 1px dashed var(--line);
    border-radius: 18px;
    color: var(--muted);
    background: color-mix(in srgb, var(--card-solid) 38%, transparent);
  }

  code {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.12rem 0.35rem;
    background: color-mix(in srgb, var(--accent-soft) 50%, transparent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
  }

  .page-main { display: grid; gap: 18px; }
  .page-title h1 { font-size: clamp(2rem, 4.2vw, 3.6rem); }
  .compact-title { padding: 24px; }
  .compact-title h1 { font-size: clamp(1.8rem, 3.6vw, 3rem); }
  .page-title p { max-width: 760px; margin-bottom: 0; }

  .blog-index { display: grid; gap: 22px; }
  .compact-blog-index { gap: 18px; }
  .blog-page-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 18px;
    padding: 8px 2px 0;
  }
  .blog-page-head h1 {
    margin: 0;
    font-size: clamp(2.6rem, 7vw, 5.2rem);
    line-height: 0.95;
    letter-spacing: -0.075em;
  }
  .blog-page-head p { margin: 10px 0 0; font-size: 0.94rem; }
  .blog-page-head a { color: var(--accent); font-size: 0.94rem; font-weight: 720; }
  .blog-shell { display: grid; grid-template-columns: 260px minmax(0, 1fr); gap: 22px; align-items: start; }
  .blog-shell-rightbar { grid-template-columns: minmax(0, 1fr) 330px; }
  .right-sidebar { display: grid; gap: 18px; position: sticky; top: 98px; }
  .sidebar-section { padding: 22px; }
  .sidebar-heading { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .sidebar-heading h2 { margin: 0; font-size: 0.92rem; letter-spacing: -0.01em; }
  .sidebar-heading span { color: var(--accent); }
  .sidebar-list { display: grid; gap: 9px; }
  .sidebar-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding: 13px 14px;
    border: 1px solid var(--line);
    border-radius: 18px;
    color: var(--text);
    background: color-mix(in srgb, var(--card-solid) 34%, transparent);
  }
  .sidebar-list a:hover { background: var(--accent-soft); }
  .post-grid { display: grid; gap: 18px; }
  .post-card {
    position: relative;
    display: grid;
    grid-template-columns: minmax(220px, 34%) minmax(0, 1fr);
    gap: 0;
    min-height: 260px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 30px;
    background: var(--card);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
    transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
  }
  .image-post-card {
    grid-template-columns: 1fr;
    min-height: 230px;
    isolation: isolate;
  }
  .post-card:hover { transform: translateY(-5px); border-color: color-mix(in srgb, var(--accent) 45%, var(--line)); box-shadow: 0 30px 90px rgba(34, 42, 54, 0.14); }
  .post-cover { position: relative; margin: 0; min-height: 240px; overflow: hidden; background: linear-gradient(135deg, var(--accent-soft), var(--violet-soft)); }
  .image-post-card .post-cover { position: absolute; inset: 0; z-index: -2; min-height: 100%; }
  .image-post-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(90deg, rgba(5, 8, 14, 0.9), rgba(5, 8, 14, 0.66) 42%, rgba(5, 8, 14, 0.2));
  }
  .post-cover img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 500ms ease; }
  .post-card:hover .post-cover img { transform: scale(1.06); }
  .generated-cover { display: grid; place-items: center; height: 100%; color: #fff; font-size: 4rem; font-weight: 900; }
  .post-card-body { display: grid; align-content: center; gap: 12px; padding: clamp(22px, 4vw, 34px); }
  .image-post-card .post-card-body { max-width: 720px; min-height: 230px; padding-right: 64px; }
  .post-card-meta { display: flex; flex-wrap: wrap; gap: 10px; color: rgba(255,255,255,0.7); font-size: 0.86rem; }
  .post-card h2 { margin: 0; font-size: clamp(1.15rem, 2vw, 1.62rem); line-height: 1.18; letter-spacing: -0.035em; color: #fff; }
  .post-card p { margin: 0; color: rgba(255,255,255,0.78); }
  .post-arrow { position: absolute; right: 24px; top: 50%; translate: 0 -50%; color: rgba(255,255,255,0.82); font-size: 2.2rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .tag {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 9px;
    color: var(--accent-strong);
    background: var(--accent-soft);
    font-size: 0.8rem;
  }
  a.tag:hover { color: var(--text); background: color-mix(in srgb, var(--accent-soft) 70%, var(--card-solid)); }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 820px) 280px;
    gap: 24px;
    align-items: start;
    justify-content: start;
  }
  .article { padding: clamp(26px, 5vw, 56px); min-width: 0; }
  .back-link { display: inline-flex; margin-bottom: 28px; color: var(--accent); font-weight: 750; }
  .article h1 { margin: 0; font-size: clamp(1.95rem, 4.6vw, 3.4rem); line-height: 1.04; letter-spacing: -0.055em; }
  .article-description { max-width: 720px; font-size: 1rem; }
  .article-meta { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; margin: 18px 0; }
  .article-meta span,
  .article-meta a {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 9px;
    color: var(--accent-strong);
    background: var(--accent-soft);
    font-size: 0.82rem;
  }
  .article-meta a:hover { color: var(--text); }
  .article-cover { margin: 30px 0 0; overflow: hidden; border: 1px solid var(--line); border-radius: 24px; background: var(--accent-soft); }
  .article-cover img { display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }
  .paper-card,
  .paper-figures figure,
  .comments-panel,
  .archive-list {
    margin-top: 24px;
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 18px;
    background: color-mix(in srgb, var(--card-solid) 45%, transparent);
  }
  .paper-links { display: flex; flex-wrap: wrap; gap: 10px; }
  .paper-links a {
    display: inline-flex;
    align-items: stretch;
    gap: 8px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text);
  }
  .paper-links span { display: inline-flex; align-items: center; padding: 6px 10px; color: var(--accent-strong); background: var(--accent-soft); font-size: 0.82rem; }
  .paper-links a { padding-right: 10px; }
  .paper-links a:hover { background: var(--accent-soft); }
  .paper-figures { display: grid; gap: 18px; margin-top: 28px; }
  .paper-figures figure { margin: 0; }
  .paper-figures img { display: block; width: 100%; border-radius: 14px; }
  .paper-figures figcaption { margin-top: 10px; color: var(--muted); font-size: 0.9rem; }
  .article-body { margin-top: 34px; }
  .article-body h2 { scroll-margin-top: 110px; margin-top: 2em; font-size: 1.32rem; letter-spacing: -0.025em; }
  .article-body h3 { scroll-margin-top: 110px; margin-top: 1.6em; font-size: 1.08rem; }
  .article-body p, .article-body li { color: var(--text); line-height: 1.92; }
  .article-body a { color: var(--accent-strong); text-decoration: underline; text-underline-offset: 0.18em; }
  .article-body blockquote { margin: 24px 0; padding: 4px 0 4px 18px; border-left: 3px solid var(--accent); color: var(--muted); }
  .article-body pre {
    overflow-x: auto;
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: color-mix(in srgb, var(--card-solid) 55%, transparent);
  }
  .toc-panel { position: sticky; top: 98px; padding: 22px; max-height: calc(100vh - 118px); overflow: auto; }
  .toc-title { margin: 0 0 14px; color: var(--accent); font-size: 0.74rem; font-weight: 850; letter-spacing: 0.14em; }
  .toc-nav { display: grid; gap: 6px; }
  .toc-nav a {
    display: block;
    border-left: 2px solid var(--line);
    padding: 7px 0 7px 12px;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.35;
  }
  .toc-nav a:hover { border-left-color: var(--accent); color: var(--text); }
  .toc-depth-3 { margin-left: 12px; font-size: 0.84rem !important; }
  .archive-list { display: grid; gap: 22px; }
  .archive-year { display: grid; gap: 10px; }
  .archive-year-title { color: var(--accent); font-size: 1.2rem; font-weight: 800; }
  .archive-posts { display: grid; gap: 8px; }
  .archive-posts a { display: grid; grid-template-columns: 70px minmax(0, 1fr); gap: 12px; align-items: baseline; padding: 10px 0; border-top: 1px solid var(--line); }
  .archive-posts span { color: var(--text); }

  .read-progress {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 100;
    width: 100%;
    height: 3px;
    transform: scaleX(0);
    transform-origin: left;
    background: linear-gradient(90deg, var(--accent), #b8efff);
  }
  .cursor-glow {
    position: fixed;
    left: -120px;
    top: -120px;
    z-index: 0;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    pointer-events: none;
    background: radial-gradient(circle, rgba(128, 189, 215, 0.22), transparent 68%);
    mix-blend-mode: plus-lighter;
    transition: transform 90ms linear;
  }
  .particle-layer { position: fixed; inset: 0; z-index: 999; pointer-events: none; overflow: hidden; }
  .particle-layer span {
    position: absolute;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent-strong);
    animation: particle-pop 720ms ease-out forwards;
  }
  @keyframes particle-pop {
    to { transform: translate(var(--dx), var(--dy)) scale(0); opacity: 0; }
  }

  @media (max-width: 900px) {
    .layout,
    .two-column,
    .blog-shell,
    .blog-shell-rightbar,
    .post-card,
    .article-layout { grid-template-columns: 1fr; }
    .blog-page-head { align-items: start; flex-direction: column; }
    .profile-card,
    .right-sidebar,
    .toc-panel { position: static; }
    .topbar {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
      align-items: stretch;
      top: 8px;
      padding: 12px;
      border-radius: 22px;
    }
    .brand { padding: 0 4px; }
    nav {
      display: flex;
      justify-content: flex-start;
      gap: 8px;
      overflow-x: auto;
      padding: 2px 2px 6px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    nav::-webkit-scrollbar { display: none; }
    nav a {
      flex: 0 0 auto;
      background: var(--accent-soft);
      color: var(--text);
    }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .toc-panel { max-height: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor-glow,
    .particle-layer { display: none; }
    *, *::before, *::after { scroll-behavior: auto !important; transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
  }

  @media (max-width: 560px) {
    .page { width: min(100% - 20px, 1180px); padding-top: 10px; }
    .topbar { margin-bottom: 14px; }
    nav a { padding: 8px 10px; font-size: 0.88rem; }
