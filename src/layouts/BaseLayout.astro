---
import { navItems, profile, sitePath } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const { title = `${profile.name} • Personal Site`, description = 'Eric Zhang 的个人主页：研究、笔记、项目与博客。' } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={sitePath('favicon.svg')} />
    <link rel="icon" href={sitePath('favicon.ico')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="page">
      <header class="topbar">
        <a class="brand" href={sitePath()}>{profile.brand}</a>
        <nav aria-label="Primary navigation">
          {navItems.map((item) => <a href={sitePath(item.href)}>{item.label}</a>)}
        </nav>
      </header>

      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --bg: #f7f8fb;
    --card: rgba(255, 255, 255, 0.82);
    --card-solid: #ffffff;
    --text: #20232a;
    --muted: #69707d;
    --line: rgba(31, 35, 42, 0.09);
    --accent: #659eb9;
    --accent-soft: rgba(101, 158, 185, 0.18);
    --shadow: 0 18px 45px rgba(34, 42, 54, 0.08);
    font-family:
      ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "PingFang SC", "Microsoft YaHei", sans-serif;
    background: var(--bg);
    color: var(--text);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0b0b10;
      --card: rgba(22, 24, 31, 0.78);
      --card-solid: #151820;
      --text: #f4f6fb;
      --muted: #a1a7b3;
      --line: rgba(255, 255, 255, 0.1);
      --accent: #80bdd7;
      --accent-soft: rgba(128, 189, 215, 0.16);
      --shadow: 0 18px 50px rgba(0, 0, 0, 0.24);
    }
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at 14% 10%, var(--accent-soft), transparent 28rem),
      radial-gradient(circle at 84% 0%, rgba(184, 210, 225, 0.18), transparent 24rem),
      var(--bg);
  }

  a { color: inherit; text-decoration: none; }

  .page {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 22px 0 56px;
  }

  .topbar {
    position: sticky;
    top: 14px;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 12px 14px;
    margin-bottom: 24px;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: color-mix(in srgb, var(--card-solid) 78%, transparent);
    box-shadow: var(--shadow);
    backdrop-filter: blur(16px);
  }

  .brand { font-weight: 800; letter-spacing: -0.02em; }

  nav {
    display: flex;
    flex: 1;
    justify-content: center;
    gap: 4px;
  }

  nav a {
    border-radius: 999px;
    padding: 8px 12px;
    color: var(--muted);
    font-size: 0.92rem;
  }

  nav a:hover { background: var(--accent-soft); color: var(--text); }

  .layout {
    display: grid;
    grid-template-columns: 320px minmax(0, 1fr);
    gap: 22px;
    align-items: start;
  }

  .card,
  .profile-card {
    border: 1px solid var(--line);
    border-radius: 28px;
    background: var(--card);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .profile-card {
    position: sticky;
    top: 98px;
    padding: 28px;
  }

  .avatar {
    display: grid;
    place-items: center;
    width: 96px;
    height: 96px;
    margin-bottom: 20px;
    border-radius: 30px;
    background: linear-gradient(135deg, rgba(101, 158, 185, 0.85), rgba(167, 201, 216, 0.55));
    color: #fff;
    font-size: 3rem;
    font-weight: 900;
  }

  .profile-card h1,
  .page-title h1 {
    margin: 0;
    letter-spacing: -0.04em;
  }

  .profile-card h1 { font-size: 2rem; }
  .location { margin: 8px 0 16px; color: var(--muted); }
  .links { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }

  .links a,
  .chips span,
  .pill {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 11px;
    background: var(--accent-soft);
    color: var(--text);
    font-size: 0.9rem;
  }

  .profile-card h2,
  .section-title h2 {
    margin: 0;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
  }

  p { color: var(--muted); line-height: 1.75; }
  .content { display: grid; gap: 18px; }
  .intro { padding: 38px; }

  .kicker {
    margin: 0 0 10px;
    color: var(--accent);
    font-size: 0.86rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .intro h2 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(2.5rem, 6vw, 5.8rem);
    line-height: 0.96;
    letter-spacing: -0.075em;
  }

  .intro p { max-width: 720px; font-size: 1.05rem; }

  .more {
    display: inline-flex;
    margin-top: 8px;
    color: var(--accent);
    font-weight: 750;
  }

  .two-column {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .two-column .card,
  .stats,
  .activity,
  .list-card,
  .page-title { padding: 26px; }

  .section-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 18px;
  }

  .section-title span,
  time { color: var(--muted); font-size: 0.86rem; }
  .chips { display: flex; flex-wrap: wrap; gap: 10px; }
  .timeline, .item-list { display: grid; gap: 14px; }

  .timeline article,
  .item-list article,
  .item-list a {
    display: block;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--line);
  }

  .timeline article:last-child,
  .item-list article:last-child,
  .item-list a:last-child { padding-bottom: 0; border-bottom: 0; }
  .timeline h3, .item-list h3 { margin: 0 0 4px; font-size: 1rem; }
  .timeline p, .item-list p { margin: 0; font-size: 0.92rem; }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .stats div {
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 22px;
    background: color-mix(in srgb, var(--accent-soft) 52%, transparent);
  }

  .stats strong { display: block; font-size: 2rem; letter-spacing: -0.05em; }
  .stats span { color: var(--muted); font-size: 0.88rem; }

  .empty {
    margin: 0;
    padding: 18px;
    border: 1px dashed var(--line);
    border-radius: 18px;
    color: var(--muted);
    background: color-mix(in srgb, var(--card-solid) 38%, transparent);
  }

  .page-main { display: grid; gap: 18px; }
  .page-title h1 { font-size: clamp(2.2rem, 5vw, 4.5rem); }
  .page-title p { max-width: 760px; margin-bottom: 0; }

  @media (max-width: 900px) {
    .layout,
    .two-column { grid-template-columns: 1fr; }
    .profile-card { position: static; }
    nav { display: none; }
    .stats { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .page { width: min(100% - 20px, 1180px); }
    .intro { padding: 28px; }
    .intro h2 { font-size: 2.5rem; }
    .stats { grid-template-columns: 1fr; }
  }
</style>
