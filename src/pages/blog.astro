---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { sitePath } from '../data/site';
import { blogCollections, collectionHref, slugify, tagHref } from '../data/blog';

const blogPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const collectionSlugs = new Set(blogCollections.map((collection) => collection.slug));
const postCollections = Array.from(new Set(blogPosts.map((post) => post.data.category ?? 'Research')))
  .filter((category) => !collectionSlugs.has(slugify(category)))
  .map((category) => ({ label: category, slug: slugify(category), href: `blog/collections/${slugify(category)}/` }));
const collections = [...blogCollections, ...postCollections];
const tags = Array.from(new Set(blogPosts.flatMap((post) => post.data.tags))).sort((a, b) => a.localeCompare(b));
const totalPosts = blogPosts.length;
---

<BaseLayout title="Blog • Eric Zhang">
  <main class="blog-index compact-blog-index">
    <section class="page-title card blog-page-title">
      <div>
        <h1>Blog</h1>
        <p>Page 1 - Showing {totalPosts} of {totalPosts} posts</p>
      </div>
      <a href={sitePath('blog/archive/')}>View all posts by years →</a>
    </section>

    <section class="blog-shell blog-shell-rightbar">
      <section class="post-grid" id="research">
        {
          blogPosts.map((post) => {
            const slug = post.id.replace(/\.(md|mdx)$/, '');
            const cover = post.data.cover ? sitePath(post.data.cover) : undefined;
            const category = post.data.category ?? 'Research';
            return (
              <a class="post-card image-post-card" href={sitePath(`blog/${slug}/`)}>
                <figure class="post-cover">
                  {cover ? <img src={cover} alt={`${post.data.title} cover`} loading="lazy" /> : <div class="generated-cover">{post.data.title.slice(0, 2)}</div>}
                </figure>
                <div class="post-card-body">
                  <div class="post-card-meta">
                    <time>{post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
                    <span>{category}</span>
                  </div>
                  <h2>{post.data.title}</h2>
                  {post.data.description && <p>{post.data.description}</p>}
                  <div class="tags">
                    {post.data.tags.slice(0, 4).map((tag) => <span class="tag">{tag}</span>)}
                  </div>
                </div>
                <span class="post-arrow" aria-hidden="true">›</span>
              </a>
            );
          })
        }
      </section>

      <aside class="right-sidebar" aria-label="Blog sidebar">
        <section class="sidebar-section card">
          <div class="sidebar-heading">
            <span aria-hidden="true">▧</span>
            <h2>Collections</h2>
          </div>
          <div class="sidebar-list">
            {collections.map((collection) => <a href={sitePath(collection.href)}>{collection.label}<span>›</span></a>)}
          </div>
        </section>

        <section class="sidebar-section card">
          <div class="sidebar-heading">
            <span aria-hidden="true">#</span>
            <h2>Tags</h2>
          </div>
          <div class="tags">
            {tags.map((tag) => <a class="tag" href={tagHref(tag)}>{tag}</a>)}
          </div>
        </section>
      </aside>
    </section>
  </main>
</BaseLayout>
