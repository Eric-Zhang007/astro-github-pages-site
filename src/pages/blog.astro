---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { sitePath } from '../data/site';

const blogPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog • Eric Zhang">
  <main class="page-main">
    <section class="page-title card">
      <p class="kicker">Blog</p>
      <h1>Blog</h1>
      <p>正式发布的文章会出现在这里。文章源文件放在 <code>src/content/blog/</code>。</p>
    </section>

    <section class="card list-card">
      {
        blogPosts.length > 0 ? (
          <div class="item-list">
            {blogPosts.map((post) => (
              <a href={sitePath(`blog/${post.id.replace(/\\.(md|mdx)$/, '')}/`)}>
                <h3>{post.data.title}</h3>
                {post.data.description && <p>{post.data.description}</p>}
                <time>{post.data.date.toISOString().slice(0, 10)}</time>
              </a>
            ))}
          </div>
        ) : (
          <p class="empty">No blog posts yet.</p>
        )
      }
    </section>
  </main>
</BaseLayout>
