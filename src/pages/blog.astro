---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { sitePath } from '../data/site';

const blogPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = Array.from(new Set(blogPosts.map((post) => post.data.category ?? 'Research')));
const totalTags = Array.from(new Set(blogPosts.flatMap((post) => post.data.tags))).length;
---

<BaseLayout title="Blog • Eric Zhang">
  <main class="blog-index">
    <section class="blog-hero card">
      <div>
        <p class="kicker">Blog / Research Notes</p>
        <h1>Long-form notes for world models, embodied agents and visual reasoning.</h1>
        <p>
          用 Markdown 记录研究阅读、方法理解和工程实验。每篇文章都有封面、摘要、标签和独立页面。
        </p>
      </div>
      <aside class="blog-hero-panel" aria-label="Blog statistics">
        <span>{blogPosts.length}</span>
        <p>published posts</p>
        <span>{totalTags}</span>
        <p>research tags</p>
      </aside>
    </section>

    <section class="blog-shell">
      <aside class="collection-panel card" aria-label="Blog collections">
        <p class="kicker">Collections</p>
        <div class="collection-links">
          {categories.map((category) => <a href={`#${category.toLowerCase().replaceAll(' ', '-')}`}>{category}</a>)}
          <a href={sitePath('research/')}>Research</a>
          <a href={sitePath('notes/')}>Notes</a>
        </div>
        <p class="collection-note">文章列表采用卡片缩略图；正式内容从 <code>src/content/blog/</code> 自动读取。</p>
      </aside>

      <section class="post-grid" id="research">
        {
          blogPosts.length > 0 ? (
            blogPosts.map((post) => {
              const slug = post.id.replace(/\.(md|mdx)$/, '');
              const cover = post.data.cover ? sitePath(post.data.cover) : undefined;
              return (
                <a class="post-card" href={sitePath(`blog/${slug}/`)}>
                  <figure class="post-cover">
                    {cover ? <img src={cover} alt={`${post.data.title} cover`} loading="lazy" /> : <div class="generated-cover">{post.data.title.slice(0, 2)}</div>}
                  </figure>
                  <div class="post-card-body">
                    <div class="post-card-meta">
                      <time>{post.data.date.toISOString().slice(0, 10)}</time>
                      <span>{post.data.category ?? 'Research'}</span>
                    </div>
                    <h2>{post.data.title}</h2>
                    {post.data.description && <p>{post.data.description}</p>}
                    <div class="tags">
                      {post.data.tags.slice(0, 4).map((tag) => <span class="tag">{tag}</span>)}
                    </div>
                  </div>
                </a>
              );
            })
          ) : (
            <p class="empty">No blog posts yet.</p>
          )
        }
      </section>
    </section>
  </main>
</BaseLayout>
