---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { comments, sectionCollections, tagHref } from '../../data/blog';
import { sitePath } from '../../data/site';

export async function getStaticPaths() {
  const posts = (await getCollection('blog'))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const allPosts = (await getCollection('blog'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const { Content, headings } = await render(post);
const slug = post.id.replace(/\.(md|mdx)$/, '');
const postIndex = allPosts.findIndex((item) => item.id === post.id);
const previousPost = postIndex >= 0 ? allPosts[postIndex + 1] : undefined;
const nextPost = postIndex > 0 ? allPosts[postIndex - 1] : undefined;
const cover = post.data.cover ? sitePath(post.data.cover) : undefined;
const toc = headings.filter((heading) => heading.depth > 1 && heading.depth < 4);
const readMinutes = Math.max(1, Math.ceil(post.body.split(/\s+/).filter(Boolean).length / 320));
const arxivUrl = post.data.paperUrl ?? (post.data.arxivId ? `https://arxiv.org/abs/${post.data.arxivId}` : undefined);
const translationUrl = post.data.translationUrl ?? (post.data.arxivId ? `https://hjfy.top/arxiv/${post.data.arxivId}` : undefined);
const showComments = post.data.comments && comments.enabled;
const collection = post.data.collection
  ? sectionCollections.blog.find((item) => item.slug === post.data.collection)
  : undefined;
const collectionPosts = post.data.collection
  ? allPosts.filter((item) => item.data.collection === post.data.collection)
  : [];
const pageUrl = `https://eric-zhang007.github.io/astro-github-pages-site/blog/${slug}/`;
const licenseHref = 'https://creativecommons.org/licenses/by-nc-sa/4.0/';
---

<BaseLayout title={`${post.data.title} • Eric Zhang`} description={post.data.description}>
  <div class="read-progress" aria-hidden="true"></div>
  <main class="article-layout">
    <article class="article card">
      <a class="back-link" href={sitePath('blog/')}>← Back to Blog</a>
      <header class="article-header">
        <p class="kicker">{post.data.category ?? 'Blog'}</p>
        <h1>{post.data.title}</h1>
        <div class="article-meta">
          <time>{post.data.date.toISOString().slice(0, 10)}</time>
          {post.data.updated && <span>Update {post.data.updated.toISOString().slice(0, 10)}</span>}
          <span>{readMinutes} min read</span>
          {post.data.tags.map((tag) => <a href={tagHref(tag)}>{tag}</a>)}
        </div>
        {post.data.description && <p class="article-description">{post.data.description}</p>}
        {
          (arxivUrl || translationUrl || post.data.codeUrl) && (
            <div class="paper-links paper-links-inline" aria-label="Paper links">
              {arxivUrl && <a href={arxivUrl} target="_blank" rel="noreferrer"><span>Arxiv ID</span>{post.data.arxivId ?? 'Paper'}</a>}
              {translationUrl && <a class="translation-link" href={translationUrl} target="_blank" rel="noreferrer"><span>幻觉翻译</span>{post.data.arxivId ?? 'Open'}</a>}
              {post.data.codeUrl && <a href={post.data.codeUrl} target="_blank" rel="noreferrer"><span>Code</span>GitHub</a>}
            </div>
          )
        }
        {
          collection && collectionPosts.length > 0 && (
            <nav class="collection-list card" aria-label={`${collection.label} posts`}>
              <p>{collection.label}</p>
              {collectionPosts.map((item, index) => {
                const itemSlug = item.id.replace(/\.(md|mdx)$/, '');
                return <a class={item.id === post.id ? 'active' : ''} href={sitePath(`blog/${itemSlug}/`)}>Batch {index + 1}</a>;
              })}
            </nav>
          )
        }
        {
          cover && (
            <figure class="article-cover">
              <img src={cover} alt={`${post.data.title} cover`} />
            </figure>
          )
        }
      </header>

      <div class="article-body">
        <Content />
      </div>

      {
        post.data.figures.length > 0 && (
          <section class="paper-figures" aria-label="Paper figures">
            {post.data.figures.map((figure) => (
              <a class="paper-figure-link" href={sitePath(figure.src)} target="_blank" rel="noreferrer">
                <figure>
                  <img src={sitePath(figure.src)} alt={figure.alt ?? ''} loading="lazy" />
                  {figure.caption && <figcaption>{figure.caption}</figcaption>}
                </figure>
              </a>
            ))}
          </section>
        )
      }

      <section class="article-info-card" aria-label="Article information">
        <div>
          <h2>{post.data.title}</h2>
          <p>{pageUrl}</p>
          <dl>
            <div>
              <dt>Author</dt>
              <dd>Eric Zhang</dd>
            </div>
            <div>
              <dt>Published at</dt>
              <dd>{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</dd>
            </div>
            <div>
              <dt>Copyright</dt>
              <dd><a href={licenseHref} target="_blank" rel="noreferrer">CC BY-NC-SA 4.0</a></dd>
            </div>
          </dl>
          <div class="article-share-row">
            <a href={pageUrl} aria-label="Open article link">↗</a>
            <button type="button" data-copy-link={pageUrl} aria-label="Copy article link">⌁</button>
            <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noreferrer" aria-label="Share to X">𝕏</a>
            <a href={`https://bsky.app/intent/compose?text=${encodeURIComponent(`${post.data.title} ${pageUrl}`)}`} target="_blank" rel="noreferrer" aria-label="Share to Bluesky">🦋</a>
          </div>
        </div>
        <span class="copyright-mark" aria-hidden="true">©</span>
      </section>

      <a class="coffee-bar" href="https://github.com/sponsors/Eric-Zhang007" target="_blank" rel="noreferrer">
        <span>Buy me a cup of coffee ☕.</span>
        <span>$</span>
      </a>

      <nav class="post-neighbors" aria-label="Adjacent posts">
        <div>
          {previousPost && <a href={sitePath(`blog/${previousPost.id.replace(/\.(md|mdx)$/, '')}/`)}>‹ {previousPost.data.title}</a>}
        </div>
        <div>
          {nextPost && <a href={sitePath(`blog/${nextPost.id.replace(/\.(md|mdx)$/, '')}/`)}>{nextPost.data.title} ›</a>}
        </div>
      </nav>

      {
        showComments && (
          <section class="comments-panel" aria-label="Comments">
            <div class="comments-heading">
              <span>Comments</span>
            </div>
            <script
              src="https://utteranc.es/client.js"
              repo={comments.repo}
              issue-term={comments.issueTerm}
              label={comments.label}
              theme={comments.theme}
              crossorigin="anonymous"
              async
            ></script>
          </section>
        )
      }
    </article>

    <aside class="toc-panel card" aria-label="Table of contents">
      <p class="toc-title">CONTENTS</p>
      {
        toc.length > 0 && (
          <nav class="toc-nav">
            {toc.map((heading) => (
              <a class={`toc-depth-${heading.depth}`} href={`#${heading.slug}`}>{heading.text}</a>
            ))}
          </nav>
        )
      }
    </aside>
  </main>
  <script>
    document.querySelectorAll('[data-copy-link]').forEach((button) => {
      button.addEventListener('click', async () => {
        if (button instanceof HTMLButtonElement) {
          await navigator.clipboard.writeText(button.dataset.copyLink ?? location.href);
          button.textContent = '✓';
          window.setTimeout(() => { button.textContent = '⌁'; }, 1200);
        }
      });
    });
  </script>
</BaseLayout>
