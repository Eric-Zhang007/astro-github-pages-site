---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { sitePath } from '../../../data/site';
import { sectionCollections, slugify } from '../../../data/blog';

export async function getStaticPaths() {
  return sectionCollections.blog.map((collection) => ({ params: { collection: collection.slug }, props: { collection } }));
}

const { collection } = Astro.props;
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft && post.data.category && slugify(post.data.category) === collection.slug)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={`${collection.label} • Collections • Eric Zhang`}>
  <main class="page-main tag-page">
    <section class="page-title card compact-title">
      <p class="kicker">Collection</p>
      <h1>{collection.label}</h1>
    </section>

    <section class="post-grid">
      {posts.map((post) => {
        const slug = post.id.replace(/\.(md|mdx)$/, '');
        const cover = post.data.cover ? sitePath(post.data.cover) : undefined;
        return (
          <a class="post-card image-post-card" href={sitePath(`blog/${slug}/`)}>
            <figure class="post-cover">
              {cover ? <img src={cover} alt={`${post.data.title} cover`} loading="lazy" /> : <div class="generated-cover">{post.data.title.slice(0, 2)}</div>}
            </figure>
            <div class="post-card-body">
              <div class="post-card-meta">
                <time>{post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
                {post.data.category && <span>{post.data.category}</span>}
              </div>
              <h2>{post.data.title}</h2>
              {post.data.description && <p>{post.data.description}</p>}
            </div>
            <span class="post-arrow" aria-hidden="true">›</span>
          </a>
        );
      })}
    </section>
  </main>
</BaseLayout>
