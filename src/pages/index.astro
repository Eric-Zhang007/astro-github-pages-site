---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileCard from '../components/ProfileCard.astro';
import {
  activities,
  blogPosts,
  educationEntries,
  profile,
  researchInterests,
  sitePath,
  stats,
} from '../data/site';
---

<BaseLayout>
  <main class="layout">
    <ProfileCard />

    <section class="content">
      <section class="intro card">
        <p class="kicker">Personal homepage</p>
        <h2>{profile.headline}</h2>
        <p>{profile.description}</p>
        <a class="more" href={sitePath('about/')}>More about me →</a>
      </section>

      <section class="two-column">
        <div class="card">
          <div class="section-title">
            <h2>Research interests</h2>
            <span>真实方向</span>
          </div>
          <div class="chips">
            {researchInterests.map((item) => <span>{item}</span>)}
          </div>
        </div>

        <div class="card">
          <div class="section-title">
            <h2>Education</h2>
            <span>真实经历</span>
          </div>
          {
            educationEntries.length > 0 ? (
              <div class="timeline">
                {educationEntries.map((item) => (
                  <article>
                    <div>
                      <h3>{item.school}</h3>
                      <p>{item.degree}</p>
                      {item.description && <p>{item.description}</p>}
                    </div>
                    <time>{item.period}</time>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty">No education entries published yet.</p>
            )
          }
        </div>
      </section>

      <section class="stats card" aria-label="Site status">
        {stats.map((item) => (
          <div>
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </div>
        ))}
      </section>

      <section class="card list-card">
        <div class="section-title">
          <h2>Blog</h2>
          <span>文章</span>
        </div>
        {
          blogPosts.length > 0 ? (
            <div class="item-list">
              {blogPosts.map((post) => (
                <a href={post.href}>
                  <h3>{post.title}</h3>
                  {post.summary && <p>{post.summary}</p>}
                  <time>{post.date}</time>
                </a>
              ))}
            </div>
          ) : (
            <p class="empty">No blog posts yet.</p>
          )
        }
      </section>

      <section class="card activity">
        <div class="section-title">
          <h2>Activity</h2>
          <span>真实更新</span>
        </div>
        {
          activities.length > 0 ? (
            <div class="item-list">
              {activities.map((item) => (
                <article>
                  <h3>{item.title}</h3>
                  <time>{item.date}</time>
                </article>
              ))}
            </div>
          ) : (
            <p class="empty">No activity yet.</p>
          )
        }
      </section>
    </section>
  </main>
</BaseLayout>
