---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { notes, sitePath } from '../data/site';
---

<BaseLayout title="Notes • Eric Zhang">
  <main class="page-main">
    <PageHeader title="Notes" count={notes.length} itemLabel="notes" actionLabel="View all notes →" actionHref={sitePath('notes/')} />

    <section class="card list-card">
      {
        notes.length > 0 ? (
          <div class="item-list">
            {notes.map((note) => (
              <a href={note.href}>
                <h3>{note.title}</h3>
                {note.summary && <p>{note.summary}</p>}
                <time>{note.date}</time>
              </a>
            ))}
          </div>
        ) : null
      }
    </section>
  </main>
</BaseLayout>
