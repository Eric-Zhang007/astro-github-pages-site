---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { projects, sitePath } from '../data/site';
---

<BaseLayout title="Projects • Eric Zhang">
  <main class="page-main">
    <PageHeader title="Projects" count={projects.length} itemLabel="projects" actionLabel="View all projects →" actionHref={sitePath('projects/')} />

    <section class="card list-card">
      {
        projects.length > 0 ? (
          <div class="item-list">
            {projects.map((project) => (
              <a href={project.href}>
                <h3>{project.title}</h3>
                {project.summary && <p>{project.summary}</p>}
              </a>
            ))}
          </div>
        ) : null
      }
    </section>
  </main>
</BaseLayout>
